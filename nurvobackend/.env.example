# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_TIMEOUT=30

# DALL-E 3 背景圖生成
DALLE_MODEL=dall-e-3
DALLE_SIZE=1792x1024
DALLE_QUALITY=standard
DALLE_TIMEOUT=60

# Eleven Labs TTS
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
ELEVENLABS_PATIENT_VOICE_ID=your-patient-voice-id
ELEVENLABS_FAMILY_VOICE_ID=your-family-voice-id

# Game Settings
GAME_TIME_LIMIT=480

# Proactive Speech (NPC 主動發話)
# PROACTIVE_ENABLED: true/false，一鍵停用主動發話（預設 true）
# PROACTIVE_IDLE_THRESHOLDS: 閒置門檻秒數，逗號分隔，依 streak 遞進使用（預設 25,20,15；超出長度後維持最後一個）
# PROACTIVE_COOLDOWN_SECONDS: 兩次主動發話之間最小間隔秒數（預設 10）
# PROACTIVE_ENDGAME_GUARD_SECONDS: 剩餘遊戲時間少於此值時不觸發（預設 30）
# RECONNECT_GRACE_SECONDS: WebSocket 重連後保留多少秒不判定為閒置（預設 10）
PROACTIVE_ENABLED=true
PROACTIVE_IDLE_THRESHOLDS=25,20,15
PROACTIVE_COOLDOWN_SECONDS=10
PROACTIVE_ENDGAME_GUARD_SECONDS=30
RECONNECT_GRACE_SECONDS=10
